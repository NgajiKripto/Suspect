{
  "name": "suspected-frontend-tests",
  "version": "1.0.0",
  "description": "Frontend security tests for suspected.dev index.html",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:security": "jest tests/security.test.js",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ]
  }
}
